{
  "name": "course-management-backend",
  "version": "1.0.0",
  "description": "Course Management Admin Panel Backend API - TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "prod": "npm run clean && npm run build && npm start",
    "seed:admins": "ts-node -r tsconfig-paths/register src/scripts/seedAdmins.ts",
    "seed:courses": "ts-node -r tsconfig-paths/register src/scripts/seedCourses.ts",
    "seed:schedules": "ts-node -r tsconfig-paths/register src/scripts/seedSchedules.ts",
    "seed:registrations": "ts-node -r tsconfig-paths/register src/scripts/seedRegistrations.ts",
    "seed:all": "npm run seed:admins && npm run seed:courses && npm run seed:schedules && npm run seed:registrations",
    "drizzle:migrate": "drizzle-kit push",
    "drizzle:generate": "drizzle-kit introspect",
    "drizzle:studio": "drizzle-kit studio"
  },
  "keywords": [
    "course",
    "management",
    "admin",
    "api",
    "typescript",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@types/express-session": "^1.18.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.19.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "stripe": "^20.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.5",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.19.31",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
